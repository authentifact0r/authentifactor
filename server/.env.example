# Sovereign Local AI — environment variables
#
# Copy to .env or .env.local. The server reads via pm2 --update-env,
# consuming apps read via process.env in their Next.js / Node runtime.

# ─── Server-side (local-ai-server) ─────────────────────────

# Bind address. Keep loopback-only in production — Cloudflare Tunnel
# reaches us via localhost. Set to 0.0.0.0 only if you deliberately
# want LAN access without a tunnel.
LOCAL_AI_HOST=127.0.0.1
LOCAL_AI_PORT=4100

# Bearer token for every route except /health. Load from:
#   $(cat ~/.local-ai/authentifactor/token.txt)
LOCAL_AI_TOKEN=

# Vault to index
OBSIDIAN_VAULT_PATH=/Users/olu/Documents/ObsidianVault

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_FAST_MODEL=llama3.1:8b
OLLAMA_SMART_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_KEEP_ALIVE=-1

# Indexer tuning
EMBED_CONCURRENCY=6

# RAG knobs
LOCAL_AI_RERANK=true

# Sovereignty
OFFLINE_MODE=true

# Watcher
LOCAL_AI_WATCH=true

# ─── Consuming apps (CitiesTroves, Careceutical, Bowsea, etc.) ────

# Use the public URL in prod, localhost in dev
# LOCAL_AI_URL=https://ai.olu.dev
LOCAL_AI_URL=http://localhost:4100

# Same token as above — distribute via your secret manager
# LOCAL_AI_TOKEN=
